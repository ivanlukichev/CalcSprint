{
  "manifest_version": 3,
  "name": "CalcSprint",
  "version": "1.0.0",
  "description": "Quick math training in your browser with speed rounds and local high scores.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "CalcSprint",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
