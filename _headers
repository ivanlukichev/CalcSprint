/blog/
  Cache-Control: no-cache, no-store, must-revalidate

/de/
  Cache-Control: no-cache, no-store, must-revalidate

/de/blog/
  Cache-Control: no-cache, no-store, must-revalidate

/es/
  Cache-Control: no-cache, no-store, must-revalidate

/es/blog/
  Cache-Control: no-cache, no-store, must-revalidate

/ru/
  Cache-Control: no-cache, no-store, must-revalidate

/ru/blog/
  Cache-Control: no-cache, no-store, must-revalidate

/zh/
  Cache-Control: no-cache, no-store, must-revalidate

/zh/blog/
  Cache-Control: no-cache, no-store, must-revalidate

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/404.html
  Cache-Control: no-cache, no-store, must-revalidate

/robots.txt
  Cache-Control: no-cache, no-store, must-revalidate

/sitemap.xml
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*.css
