/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://analytics.ahrefs.com https://*.ahrefs.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://calcsprint.com; connect-src 'self' https://analytics.ahrefs.com https://*.ahrefs.com; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests

/
